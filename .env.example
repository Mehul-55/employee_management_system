# Local MongoDB:
# MONGO_URI=mongodb://localhost:27017/

# MongoDB Atlas:
# Replace username, password, and cluster host with your Atlas values.
# Keep the database name in MONGO_DB_NAME below.
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=employee_attendance
MONGO_CONNECT_TIMEOUT_MS=5000
API_BASE_URL=http://127.0.0.1:8000

# Optional: used only by migrate_to_atlas.py.
ATLAS_MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/?retryWrites=true&w=majority
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD_HASH=your-pbkdf2-password-hash
